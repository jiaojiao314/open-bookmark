{
  "name": "open-bookmark",
  "version": "0.2.0",
  "description": "Spec-driven browser bookmark management. Define your rules first, then execute.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "open-bookmark": "./bin/open-bookmark.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE",
    "docs"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build && changeset publish",
    "prepublishOnly": "npm run build && npm run test:run"
  },
  "keywords": [
    "bookmark",
    "browser",
    "chrome",
    "ai-agent",
    "skill",
    "bookmark-management",
    "classification",
    "multi-agent"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jiaojiao314/open-bookmark.git"
  },
  "bugs": {
    "url": "https://github.com/jiaojiao314/open-bookmark/issues"
  },
  "homepage": "https://github.com/jiaojiao314/open-bookmark#readme",
  "dependencies": {
    "@inquirer/prompts": "^8.4.3",
    "commander": "^14.0.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^24.2.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  }
}
